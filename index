<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GavGavichBot_ Portfolio</title>
  <style>
    :root {
      --bg: #0e1116;
      --bg-soft: #171c24;
      --panel: rgba(24, 29, 39, 0.92);
      --panel-strong: #121720;
      --line: rgba(255, 255, 255, 0.09);
      --text: #eef2f7;
      --muted: #9eacbf;
      --accent: #ff7a18;
      --accent-2: #ffd86f;
      --success: #66e3a6;
      --danger: #ff7f8f;
      --shadow: 0 24px 80px rgba(0, 0, 0, 0.45);
      --radius-xl: 28px;
      --radius-lg: 20px;
      --radius-md: 14px;
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      font-family: Bahnschrift, "Trebuchet MS", "Segoe UI", sans-serif;
      background:
        radial-gradient(circle at top left, rgba(255, 122, 24, 0.18), transparent 28%),
        radial-gradient(circle at 85% 15%, rgba(255, 216, 111, 0.18), transparent 24%),
        linear-gradient(180deg, #0b0e13 0%, #0f1319 100%);
      color: var(--text);
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image:
        linear-gradient(rgba(255, 255, 255, 0.018) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.018) 1px, transparent 1px);
      background-size: 42px 42px;
      mask-image: radial-gradient(circle at center, black 42%, transparent 90%);
    }

    .wrap {
      width: min(1180px, calc(100% - 32px));
      margin: 0 auto;
      padding: 28px 0 72px;
    }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      margin-bottom: 34px;
      padding: 16px 18px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: rgba(17, 22, 30, 0.72);
      backdrop-filter: blur(16px);
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 14px;
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    .brand-badge {
      width: 42px;
      height: 42px;
      display: grid;
      place-items: center;
      border-radius: 14px;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      color: #111;
      font-weight: 900;
      box-shadow: 0 10px 24px rgba(255, 122, 24, 0.35);
    }

    .nav {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .nav a,
    .hero-actions a {
      color: var(--text);
      text-decoration: none;
      border: 1px solid var(--line);
      padding: 10px 16px;
      border-radius: 999px;
      transition: 0.25s ease;
    }

    .nav a:hover,
    .hero-actions a:hover {
      transform: translateY(-1px);
      border-color: rgba(255, 255, 255, 0.18);
      background: rgba(255, 255, 255, 0.04);
    }

    .hero {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 24px;
      align-items: stretch;
      margin-bottom: 28px;
    }

    .panel {
      border: 1px solid var(--line);
      background: var(--panel);
      backdrop-filter: blur(20px);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow);
    }

    .hero-copy {
      padding: 38px;
      position: relative;
      overflow: hidden;
    }

    .hero-copy::after {
      content: "";
      position: absolute;
      width: 260px;
      height: 260px;
      border-radius: 50%;
      right: -84px;
      bottom: -92px;
      background: radial-gradient(circle, rgba(255, 122, 24, 0.24), transparent 65%);
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.04);
      color: var(--accent-2);
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.12em;
    }

    h1 {
      margin: 18px 0 16px;
      font-size: clamp(2.5rem, 4vw, 4.6rem);
      line-height: 0.98;
      letter-spacing: -0.04em;
      max-width: 9.5ch;
    }

    .lead {
      margin: 0 0 22px;
      color: var(--muted);
      font-size: 1.05rem;
      line-height: 1.65;
      max-width: 58ch;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 28px;
    }

    .hero-actions .primary {
      border: none;
      color: #16120e;
      font-weight: 800;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      box-shadow: 0 18px 40px rgba(255, 122, 24, 0.25);
    }

    .stat-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
    }

    .stat {
      padding: 16px;
      border-radius: var(--radius-md);
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.06);
    }

    .stat strong {
      display: block;
      font-size: 1.35rem;
      margin-bottom: 6px;
    }

    .hero-preview {
      padding: 22px;
      display: grid;
      gap: 14px;
      align-content: start;
      background:
        linear-gradient(180deg, rgba(255, 122, 24, 0.11), transparent 32%),
        var(--panel-strong);
    }

    .window-bar {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 6px 2px 10px;
    }

    .window-bar span {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.2);
    }

    .window-bar span:nth-child(1) { background: #ff6b6b; }
    .window-bar span:nth-child(2) { background: #ffd166; }
    .window-bar span:nth-child(3) { background: #6ee7a1; }

    .preview-card {
      padding: 18px;
      border-radius: var(--radius-lg);
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.06);
    }

    .preview-card h3,
    .section-head h2,
    .feature h3,
    .deliver h3,
    .workflow h3 {
      margin: 0 0 10px;
      font-size: 1.08rem;
    }

    .terminal,
    .chat {
      display: grid;
      gap: 10px;
      font-size: 0.95rem;
    }

    .command-line,
    .chat-line {
      display: grid;
      gap: 4px;
      padding: 12px 14px;
      border-radius: 14px;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.06);
    }

    .command-line code,
    .chip,
    .code-pill {
      font-family: Consolas, "Courier New", monospace;
    }

    .label {
      color: var(--muted);
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    section {
      margin-top: 28px;
    }

    .section-shell {
      padding: 28px;
    }

    .section-head {
      display: flex;
      justify-content: space-between;
      gap: 18px;
      align-items: end;
      margin-bottom: 20px;
    }

    .section-head p {
      margin: 0;
      color: var(--muted);
      max-width: 58ch;
      line-height: 1.6;
    }

    .features,
    .deliverables,
    .workflows {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 16px;
    }

    .feature,
    .deliver,
    .workflow {
      padding: 20px;
      border-radius: var(--radius-lg);
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.06);
      min-height: 100%;
    }

    .feature p,
    .deliver p,
    .workflow p {
      margin: 0;
      color: var(--muted);
      line-height: 1.6;
    }

    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 18px;
    }

    .chip {
      padding: 10px 14px;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(255, 255, 255, 0.03);
      color: var(--text);
      cursor: pointer;
      transition: 0.22s ease;
    }

    .chip.active,
    .chip:hover {
      background: linear-gradient(135deg, rgba(255, 122, 24, 0.18), rgba(255, 216, 111, 0.1));
      border-color: rgba(255, 216, 111, 0.45);
      transform: translateY(-1px);
    }

    .demo-grid {
      display: grid;
      grid-template-columns: 0.9fr 1.1fr;
      gap: 18px;
    }

    .demo-box {
      padding: 18px;
      border-radius: var(--radius-lg);
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.06);
    }

    .demo-title {
      margin: 0 0 12px;
      font-size: 0.94rem;
      text-transform: uppercase;
      letter-spacing: 0.09em;
      color: var(--muted);
    }

    .demo-code {
      display: grid;
      gap: 12px;
      color: var(--text);
      font-family: Consolas, "Courier New", monospace;
      font-size: 0.95rem;
    }

    .demo-note {
      margin-top: 14px;
      color: var(--muted);
      line-height: 1.6;
    }

    .chat-line strong {
      font-size: 13px;
      color: var(--accent-2);
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .chat-line.bot strong {
      color: var(--success);
    }

    .chat-line.reply {
      border-left: 3px solid rgba(255, 216, 111, 0.6);
      background: rgba(255, 216, 111, 0.05);
    }

    .launch-grid {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 18px;
    }

    .launch-steps {
      display: grid;
      gap: 12px;
    }

    .launch-step {
      padding: 16px;
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.06);
    }

    .launch-step strong {
      display: block;
      margin-bottom: 6px;
    }

    .code-pill {
      display: inline-block;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255, 122, 24, 0.12);
      color: var(--accent-2);
      border: 1px solid rgba(255, 216, 111, 0.24);
    }

    footer {
      margin-top: 28px;
      padding: 22px 24px;
      border-radius: 22px;
      border: 1px solid var(--line);
      background: rgba(18, 22, 30, 0.82);
      color: var(--muted);
      text-align: center;
      line-height: 1.6;
    }

    @media (max-width: 980px) {
      .hero,
      .demo-grid,
      .launch-grid,
      .features,
      .deliverables,
      .workflows {
        grid-template-columns: 1fr;
      }

      .stat-grid {
        grid-template-columns: 1fr;
      }

      .section-head {
        align-items: start;
        flex-direction: column;
      }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <header class="topbar">
      <div class="brand">
        <div class="brand-badge">GG</div>
        <div>GavGavichBot_ • Twitch Bot Portfolio</div>
      </div>
      <nav class="nav">
        <a href="#features">Функции</a>
        <a href="#demo">Демо</a>
        <a href="#launch">Запуск</a>
      </nav>
    </header>

    <section class="hero">
      <div class="panel hero-copy">
        <div class="eyebrow">Fiverr Ready • Twitch Automation</div>
        <h1>Custom Twitch bot for streamers who want control.</h1>
        <p class="lead">
          Это портфолио показывает, как выглядит кастомный Twitch IRC-бот для стримеров. Он умеет
          отправлять команды, спамить фразы и ответы, добавлять новые команды через чат, делать reply
          на сообщение и подставлять ник пользователя. В демо ниже у стримера ник <strong>Fly</strong>,
          а бот называется <strong>GavGavichBot_</strong>.
        </p>
        <div class="hero-actions">
          <a class="primary" href="#demo">Посмотреть демо</a>
          <a href="#launch">Как запускается бот</a>
        </div>
        <div class="stat-grid">
          <div class="stat">
            <strong>2 режима</strong>
            <span>спам по шаблону и обычные кастомные команды</span>
          </div>
          <div class="stat">
            <strong>2 тега</strong>
            <span><code>%user%</code> и <code>#reply#</code> для умных ответов</span>
          </div>
          <div class="stat">
            <strong>JSON save</strong>
            <span>новые команды сохраняются и не пропадают</span>
          </div>
        </div>
      </div>

      <div class="panel hero-preview">
        <div class="window-bar"><span></span><span></span><span></span></div>
        <div class="preview-card">
          <h3>Миниатюра команды</h3>
          <div class="terminal">
            <div class="command-line">
              <span class="label">Viewer Fly</span>
              <code>!tg</code>
            </div>
            <div class="command-line">
              <span class="label">Bot GavGavichBot_</span>
              <div>Заходите в мой тг: https://t.me/your_channel</div>
            </div>
          </div>
        </div>
        <div class="preview-card">
          <h3>Reply + mention</h3>
          <div class="chat">
            <div class="chat-line">
              <strong>USER</strong>
              <div>!test</div>
            </div>
            <div class="chat-line reply bot">
              <strong>GavGavichBot_</strong>
              <div>Привет, @USER. Команда сработала reply-ответом.</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="features" class="panel section-shell">
      <div class="section-head">
        <div>
          <h2>Что умеет бот</h2>
          <p>Сайт описывает именно те функции, которые удобно продавать на Fiverr: готовая логика для стрима, живые команды, модераторские уровни и простой запуск.</p>
        </div>
      </div>
      <div class="features">
        <article class="feature">
          <h3>Обычные команды</h3>
          <p>Можно сделать стандартные ответы вроде <code>!tg</code>, <code>!discord</code>, <code>!donate</code>, <code>!map</code>. В портфолио показаны дефолтные примеры, а все тексты и ссылки легко меняются под клиента.</p>
        </article>
        <article class="feature">
          <h3>Спам команд</h3>
          <p>Бот может повторять ответ команды через формат <code>!командачисло</code>. Пример: <code>!tg3</code> отправит ответ команды <code>!tg</code> три раза подряд.</p>
        </article>
        <article class="feature">
          <h3>Спам фраз</h3>
          <p>Для старта можно настроить режим <code>!spam hello 5</code>, и тогда бот отправит фразу <code>hello</code> пять раз. Это полезно для промо, ивентов и актива в чате.</p>
        </article>
      </div>
      <div class="deliverables" style="margin-top:16px;">
        <article class="deliver">
          <h3>Добавление команд</h3>
          <p>Новые команды можно создавать прямо из чата через панель модерации или команду формата <code>!cmd add !test текст</code>. Это удобно для стримера: не нужно каждый раз заходить в код.</p>
        </article>
        <article class="deliver">
          <h3>Reply-синтаксис</h3>
          <p>Если в конце ответа есть <code>#reply#</code>, бот ответит именно реплаем на сообщение зрителя. Это выглядит живо и аккуратно в Twitch-чате.</p>
        </article>
        <article class="deliver">
          <h3>Подстановка ника</h3>
          <p>Если в тексте есть <code>%user%</code>, бот автоматически превращает это в упоминание зрителя. Пример: <code>Привет, %user%</code> станет <code>Привет, @Fly</code>.</p>
        </article>
      </div>
    </section>

    <section id="demo" class="panel section-shell">
      <div class="section-head">
        <div>
          <h2>Интерактивное демо</h2>
          <p>Ниже показаны миниатюрки того, как это можно презентовать клиенту на Fiverr: какие команды он пишет и что именно отвечает бот.</p>
        </div>
      </div>

      <div class="chips" id="demoButtons">
        <button class="chip active" data-demo="tg">!tg</button>
        <button class="chip" data-demo="tg3">!tg3</button>
        <button class="chip" data-demo="spam">!spam hello 5</button>
        <button class="chip" data-demo="add">!cmd add !test ...</button>
      </div>

      <div class="demo-grid">
        <div class="demo-box">
          <div class="demo-title">Что пишет пользователь</div>
          <div class="demo-code" id="demoCode"></div>
          <p class="demo-note" id="demoNote"></p>
        </div>
        <div class="demo-box">
          <div class="demo-title">Что отвечает GavGavichBot_</div>
          <div class="chat" id="demoChat"></div>
        </div>
      </div>
    </section>

    <section class="panel section-shell">
      <div class="section-head">
        <div>
          <h2>Что получит клиент</h2>
          <p>Сайт объясняет не только функции, но и конечный результат: бот готов к запуску, сохраняет команды и понятен даже стримеру без технички.</p>
        </div>
      </div>
      <div class="workflows">
        <article class="workflow">
          <h3>Сохранение новых команд</h3>
          <p>Все новосозданные команды сохраняются в отдельный JSON-файл. После перезапуска бота они остаются на месте и продолжают работать.</p>
        </article>
        <article class="workflow">
          <h3>Уровни доступа</h3>
          <p>Можно выдать отдельные уровни модераторам: кто может спамить команды, кто может добавлять новые ответы, а кто управляет всем как разработчик.</p>
        </article>
        <article class="workflow">
          <h3>Готовая локальная версия</h3>
          <p>В комплекте уже может быть файл для запуска в один клик. Клиент просто нажимает на него, и бот начинает работать без ручного ввода команд в консоли.</p>
        </article>
      </div>
    </section>

    <section id="launch" class="panel section-shell">
      <div class="section-head">
        <div>
          <h2>Как запускается бот</h2>
          <p>Эта часть портфолио объясняет простоту использования: для старта у клиента уже будет готовый файл запуска, а не только исходный код.</p>
        </div>
      </div>
      <div class="launch-grid">
        <div class="launch-steps">
          <div class="launch-step">
            <strong>1. Получает архив с ботом</strong>
            Внутри лежат сам бот, файл хранения команд и готовый запускатель.
          </div>
          <div class="launch-step">
            <strong>2. Нажимает на файл запуска</strong>
            <span class="code-pill">start_bot.bat</span>
          </div>
          <div class="launch-step">
            <strong>3. Бот стартует</strong>
            Дальше <strong>GavGavichBot_</strong> подключается к чату и начинает отвечать на команды.
          </div>
        </div>
        <div class="demo-box">
          <div class="demo-title">Что можно описать в Fiverr</div>
          <div class="demo-code">
            <div>• готовый бот под Twitch</div>
            <div>• кастомные команды и reply-ответы</div>
            <div>• сохранение команд после рестарта</div>
            <div>• запуск в один клик через файл</div>
            <div>• кастомизация под канал клиента</div>
          </div>
          <p class="demo-note">
            Все примеры на этой странице дефолтные и служат мини-презентацией.
            В реальном заказе тексты, ссылки, команды и стиль полностью настраиваются под стримера.
          </p>
        </div>
      </div>
    </section>

    <footer>
      Portfolio page for a custom Twitch bot by <strong>GavGavichBot_</strong>.
      Built to show Fiverr clients how commands, spam logic, saved responses and reply tags work in practice.
    </footer>
  </div>

  <script>
    const demos = {
      tg: {
        code: ["Fly: !tg"],
        note: "Пример обычной команды с дефолтной ссылкой на Telegram.",
        chat: [
          { who: "Fly", text: "!tg" },
          { who: "GavGavichBot_", text: "Заходите в мой тг: https://t.me/your_channel", bot: true }
        ]
      },
      tg3: {
        code: ["Fly: !tg3"],
        note: "Формат !командачисло повторяет ответ несколько раз.",
        chat: [
          { who: "Fly", text: "!tg3" },
          { who: "GavGavichBot_", text: "Заходите в мой тг: https://t.me/your_channel", bot: true },
          { who: "GavGavichBot_", text: "Заходите в мой тг: https://t.me/your_channel", bot: true },
          { who: "GavGavichBot_", text: "Заходите в мой тг: https://t.me/your_channel", bot: true }
        ]
      },
      spam: {
        code: ["Fly: !spam hello 5"],
        note: "Для старта можно показать спам фраз. Например, бот отправляет hello пять раз.",
        chat: [
          { who: "Fly", text: "!spam hello 5" },
          { who: "GavGavichBot_", text: "hello", bot: true },
          { who: "GavGavichBot_", text: "hello", bot: true },
          { who: "GavGavichBot_", text: "hello", bot: true },
          { who: "GavGavichBot_", text: "hello", bot: true },
          { who: "GavGavichBot_", text: "hello", bot: true }
        ]
      },
      add: {
        code: [
          "Moderator: !cmd add !test привет %user% #reply#",
          "Fly: !test"
        ],
        note: "Новая команда сохраняется, reply делает ответ именно на сообщение, а %user% превращается в @Fly.",
        chat: [
          { who: "Moderator", text: "!cmd add !test привет %user% #reply#" },
          { who: "GavGavichBot_", text: "команда !test добавлена", bot: true },
          { who: "Fly", text: "!test" },
          { who: "GavGavichBot_", text: "привет @Fly", bot: true, reply: true }
        ]
      }
    };

    const buttons = document.querySelectorAll(".chip");
    const codeBox = document.getElementById("demoCode");
    const noteBox = document.getElementById("demoNote");
    const chatBox = document.getElementById("demoChat");

    function renderDemo(key) {
      const demo = demos[key];
      codeBox.innerHTML = demo.code.map(line => `<div>${line}</div>`).join("");
      noteBox.textContent = demo.note;
      chatBox.innerHTML = demo.chat.map(item => `
        <div class="chat-line ${item.bot ? "bot" : ""} ${item.reply ? "reply" : ""}">
          <strong>${item.who}</strong>
          <div>${item.text}</div>
        </div>
      `).join("");

      buttons.forEach(button => {
        button.classList.toggle("active", button.dataset.demo === key);
      });
    }

    buttons.forEach(button => {
      button.addEventListener("click", () => renderDemo(button.dataset.demo));
    });

    renderDemo("tg");
  </script>
</body>
